# ============================================================
# Fraydi — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Google OAuth + Calendar API ───────────────────────────────
# Get these from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Google Calendar API, Google People API
# Add redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── NextAuth ──────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# ── OpenAI ────────────────────────────────────────────────────
# Used for: AI coordination suggestions, smart categorisation
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Resend (Email) ────────────────────────────────────────────
# Used for: family notification emails
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...
